<div class="container mt-5">
  <h1 class="text-center mb-4">To do list avec Ruby on Rails</h1>

  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>Title</th>
        <th>Completed</th>
        <th colspan="3">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= task.title %></td>
          <td><%= task.completed ? 'Yes' : 'No' %></td>
          <td><%= link_to 'Show', task, class: "btn btn-info btn-sm" %></td>
          <td><%= link_to 'Edit', edit_task_path(task), class: "btn btn-warning btn-sm" %></td>
          <td>
            <%= form_with(model: task, method: :delete, local: true, class: "d-inline") do |form| %>
              <%= form.submit 'Destroy', class: "btn btn-danger btn-sm", data: { confirm: 'Are you sure?' } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="text-center mt-4">
    <%= link_to 'New Task', new_task_path, class: "btn btn-success" %>
  </div>
</div>