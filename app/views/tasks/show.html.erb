<div class="container mt-5">
  <h1 class="text-center mb-4">Task Details</h1>

  <div class="card">
    <div class="card-body">
      <p class="card-text">
        <strong>Title:</strong>
        <%= @task.title %>
      </p>

      <p class="card-text">
        <strong>Completed:</strong>
        <%= @task.completed ? 'Yes' : 'No' %>
      </p>

      <div class="text-center">
        <%= link_to 'Edit', edit_task_path(@task), class: "btn btn-warning" %>
        <%= link_to 'Back', tasks_path, class: "btn btn-secondary" %>
      </div>
    </div>
  </div>
</div>